# Production Environment Variables for Open SWE Web App
# Copy this file to .env.production.local and fill in the actual values

# ------------------Production URLs-----------------
# The API URL of the proxy route in the Next.js app (your deployed Vercel app)
NEXT_PUBLIC_API_URL="https://your-vercel-app.vercel.app/api"

# The API URL of the deployed LangGraph server on LangGraph Platform
LANGGRAPH_API_URL="https://your-deployment-id.us.langsmith.com"

# ------------------GitHub App Secrets-----------------
# GitHub app client secrets. Used for the GitHub OAuth login flow.
NEXT_PUBLIC_GITHUB_APP_CLIENT_ID="your_github_app_client_id"
GITHUB_APP_CLIENT_SECRET="your_github_app_client_secret"

# Production redirect URI - must match your GitHub app settings
GITHUB_APP_REDIRECT_URI="https://your-vercel-app.vercel.app/api/auth/github/callback"

# GitHub App details
GITHUB_APP_NAME="your-github-app-name"
GITHUB_APP_ID="your_github_app_id"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your private key here...
-----END RSA PRIVATE KEY-----"

# GitHub App webhook secret (if using webhooks)
GITHUB_APP_WEBHOOK_SECRET="your_webhook_secret"

# ------------------Security & Configuration-----------------
# Encryption key for secrets (32-byte hex string for AES-256)
# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY="your_32_byte_hex_encryption_key"

# Assistant configuration
NEXT_PUBLIC_ASSISTANT_ID="your_assistant_id"

# Authentication restrictions (optional)
NEXT_PUBLIC_RESTRICT_TO_LANGCHAIN_AUTH="false"

# ------------------Additional Production Settings-----------------
# Node environment
NODE_ENV="production"

# Next.js telemetry (optional)
NEXT_TELEMETRY_DISABLED="1"
